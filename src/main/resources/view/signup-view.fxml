<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="uiController.SignUpController"
      spacing="15"
      style="-fx-background-color: #f4f6fb;"
      prefWidth="900"
      prefHeight="680">

    <padding>
        <Insets top="20" right="40" bottom="20" left="40"/>
    </padding>

    <Label text="Sign Up"
           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1f3c88;" />

    <VBox spacing="16"
          style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-border-width: 1; -fx-padding: 20;">

        <HBox spacing="20" alignment="CENTER_LEFT">
            <Label text="Nume utilizator:" minWidth="170" style="-fx-font-weight: bold;"/>
            <TextField fx:id="usernameField" prefWidth="420"/>
        </HBox>

        <HBox spacing="20" alignment="CENTER_LEFT">
            <Label text="Data nașterii:" minWidth="170" style="-fx-font-weight: bold;"/>
            <TextField fx:id="birthDateField" promptText="dd-MM-yyyy" prefWidth="420"/>
        </HBox>

        <HBox spacing="20" alignment="CENTER_LEFT">
            <Label text="Password:" minWidth="170" style="-fx-font-weight: bold;"/>

            <VBox spacing="0">
                <PasswordField fx:id="passwordField" prefWidth="420"/>
                <TextField fx:id="visiblePasswordField" prefWidth="420"/>
            </VBox>

            <Button fx:id="togglePasswordButton"
                    text="👁"
                    onAction="#handleTogglePassword"
                    prefWidth="45"
                    prefHeight="35"
                    style="-fx-font-size: 14px;"/>

            <Button text="📋"
                    onAction="#handleCopyPassword"
                    prefWidth="45"
                    prefHeight="35"
                    style="-fx-font-size: 14px;"/>
        </HBox>
    </VBox>

    <HBox spacing="18">
        <Button text="Verificare"
                onAction="#handleVerify"
                prefWidth="150"
                prefHeight="40"
                style="-fx-background-color: #1f7a1f; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>

        <Button text="Generare"
                onAction="#handleGenerate"
                prefWidth="150"
                prefHeight="40"
                style="-fx-background-color: #243f8f; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>

        <Button text="Create Account"
                onAction="#handleSignUp"
                prefWidth="190"
                prefHeight="40"
                style="-fx-background-color: #8a2be2; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>

        <Button text="Back"
                onAction="#handleBack"
                prefWidth="130"
                prefHeight="40"
                style="-fx-background-color: #8d8d8d; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
    </HBox>

    <Label fx:id="strengthLabel"
           text=""
           style="-fx-font-weight: bold; -fx-font-size: 16px;"/>

    <Label fx:id="messageLabel"
           text=""
           wrapText="true"
           style="-fx-text-fill: #c62828; -fx-font-weight: bold; -fx-font-size: 14px;"/>

    <VBox spacing="10"
          style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-border-width: 1; -fx-padding: 20;"
          VBox.vgrow="ALWAYS">
        <TextArea fx:id="resultArea"
                  wrapText="true"
                  editable="false"
                  prefHeight="260"
                  text="Rezultatul va apărea aici.\nFormat data nașterii: dd-MM-yyyy"
                  style="-fx-font-size: 14px;"/>
    </VBox>
</VBox>