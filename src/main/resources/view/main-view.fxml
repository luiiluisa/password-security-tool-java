<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="uiController.MainController"
      alignment="CENTER"
      spacing="25"
      style="-fx-background-color: #f4f6fb;">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="Password Security Tool"
           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1f3c88;" />

    <Button text="Log In"
            onAction="#handleOpenLogin"
            prefWidth="220"
            prefHeight="45"
            style="-fx-background-color: #1f7a1f; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;" />

    <Button text="Sign Up"
            onAction="#handleOpenSignUp"
            prefWidth="220"
            prefHeight="45"
            style="-fx-background-color: #1f3c88; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;" />
</VBox>
